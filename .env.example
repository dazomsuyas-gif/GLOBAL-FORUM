# .env.example - Copy to .env.local and fill with your values
# NEVER commit real keys to git!

# DATABASE
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/globalforum"

# NEXT AUTH
NEXTAUTH_SECRET="your-nextauth-secret-key (generate with openssl rand -base64 32)"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# GOOGLE OAUTH
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# FACEBOOK OAUTH
FACEBOOK_CLIENT_ID="your-facebook-client-id"
FACEBOOK_CLIENT_SECRET="your-facebook-client-secret"

# APPLE OAUTH
APPLE_CLIENT_ID="your-apple-client-id"
APPLE_CLIENT_SECRET="your-apple-client-secret"

# STRIPE PAYMENTS
STRIPE_SECRET_KEY="sk_test_your-key"
STRIPE_WEBHOOK_SECRET="whsec_your-key"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-key"

# PAYPAL
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
PAYPAL_MODE="sandbox"

# NALA MONEY (Tanzania Mobile Money)
NALA_MONEY_API_KEY="your-nala-api-key"
NALA_MONEY_API_URL="https://api.nalatrust.com/v1"

# AMADEUS (Flights & Hotels)
AMADEUS_API_KEY="your-amadeus-api-key"
AMADEUS_API_SECRET="your-amadeus-api-secret"

# RESEND (Email Service)
RESEND_API_KEY="re_your-api-key"

# TWILIO (SMS Alerts)
TWILIO_ACCOUNT_SID="AC_your-account-sid"
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# CLOUDINARY (Image Upload)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ADMIN CONTACT (for notifications)
ADMIN_EMAIL="dazomsuyas@gmail.com"
ADMIN_PHONE="+255768868546"

# WHATSAPP (for marketplace bot)
WHATSAPP_NUMBER_1="+255768868546"
WHATSAPP_NUMBER_2="+255767456512"

# GOOGLE ANALYTICS (optional)
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
